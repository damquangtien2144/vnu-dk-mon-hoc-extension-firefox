{
  "manifest_version": 3,
  "name": "Tool hỗ trợ đăng ký môn học VNU",
  "version": "1.0.0",
  "description": "Cải tiến tính năng Ctrl+F để tìm kiếm môn học nhanh chóng thông qua các thông tin trên thời khóa biểu.",
  "browser_specific_settings": {
    "gecko": {
      "id": "vnu-dk-tool@quangtien.com",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "logo/hamster-meme-goofy-hamster.png",
    "48": "logo/hamster-meme-goofy-hamster.png",
    "128": "logo/hamster-meme-goofy-hamster.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Tìm kiếm môn học VNU"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scripts/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "popup/popup.html",
        "popup/popup.css",
        "popup/popup.js",
        "assets/qr/*",
        "assets/gif/*",
        "logo/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
